# Copy to .env (and .env.local for secrets) and fill in. Never commit real values.
#
# Project coordinates + the publishable/anon key. These are safe to expose:
# the anon key is shipped in the client bundle by design and is constrained by
# Row Level Security. They are NOT a substitute for RLS.
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# SECRET — belongs in .env.local locally, and in the Cloudflare Worker secret
# store in deployed environments. Never commit a real value.
#
# Bypasses Row Level Security entirely. Server-side use only.
#   npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
